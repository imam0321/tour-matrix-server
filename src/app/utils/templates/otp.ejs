<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      padding: 20px;
    }
    .container {
      background-color: #ffffff;
      padding: 30px;
      border-radius: 10px;
      max-width: 500px;
      margin: auto;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }
    h2 {
      color: #333;
    }
    .otp {
      font-size: 24px;
      font-weight: bold;
      color: #007bff;
    }
    .note {
      color: #555;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>Hello <%= name %>,</h2>
    <p>Your OTP code is:</p>
    <p class="otp"><%= otp %></p>
    <p class="note">This code is valid for 2 minutes. Please do not share it with anyone.</p>
  </div>
</body>
</html>
